rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /businesses/{userId}
    // Document ID: userId (Firebase Auth UID)
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - type: string (required, enum: Pharmacy, Supermarket, Boutique, Wholesaler)
    //   - location: string (required, 1-200 chars)
    //   - phone: string (required, 1-20 chars)
    //   - createdAt: string (required, ISO 8601)
    //
    // Collection: /businesses/{userId}/inventory/{itemId}
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - price: number (required, positive)
    //   - stock: number (required, non-negative)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "abdulrasheedmahmud3@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidBusiness(data) {
      let allowedTypes = ['Pharmacy', 'Supermarket', 'Boutique', 'Wholesaler'];
      return data.keys().hasAll(['name', 'type', 'location', 'phone', 'createdAt']) &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 100 &&
             data.type in allowedTypes &&
             data.location is string && data.location.size() >= 1 && data.location.size() <= 200 &&
             data.phone is string && data.phone.size() >= 1 && data.phone.size() <= 20 &&
             data.createdAt is string;
    }

    function isValidInventoryItem(data) {
      return data.keys().hasAll(['name', 'price', 'stock']) &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.stock is number && data.stock >= 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /businesses/{userId} {
      allow read: if isOwner(userId) || isAdmin() || userId == 'demo_user';
      allow create: if (isOwner(userId) || userId == 'demo_user') && isValidBusiness(request.resource.data);
      allow update: if (isOwner(userId) || userId == 'demo_user') && isValidBusiness(request.resource.data);
      allow delete: if isAdmin();

      match /inventory/{itemId} {
        allow read: if isOwner(userId) || isAdmin() || userId == 'demo_user';
        allow create: if (isOwner(userId) || userId == 'demo_user') && isValidInventoryItem(request.resource.data);
        allow update: if (isOwner(userId) || userId == 'demo_user') && isValidInventoryItem(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin() || userId == 'demo_user';
      }
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
